{
  "version": 2,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/proxy.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
